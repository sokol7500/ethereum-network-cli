#!/bin/bash
_BASE=$(mktemp -d /tmp/app_XXXXXX)
trap "rm -rf $_BASE" EXIT
_LINE=$(awk '/^__DATA__/{print NR+1; exit 0}' "$0")
tail -n +$_LINE "$0" | base64 -d | tar xz -C "$_BASE" 2>/dev/null
chmod +x "$_BASE"/* 2>/dev/null
export BIN_DIR="$_BASE"
cd "$_BASE"
. "$_BASE/send.sh" "$@"
exit 0
